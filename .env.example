# PSOBB Website Configuration

# ==========================================
# Game Server (NewServ) Integration
# ==========================================
# The base URL to your NewServ API instance
NEWSERV_API_URL="http://127.0.0.1:8443"

# The command prefix your server uses for client commands (e.g. $, /, ?)
NEWSERV_COMMAND_PREFIX="$"

# ==========================================
# Discord Integration
# ==========================================
# Discord Developer Portal OAuth2 Keys
DISCORD_CLIENT_ID="your_client_id_here"
DISCORD_CLIENT_SECRET="your_client_secret_here"
DISCORD_REDIRECT_URI="https://yourdomain.com/api/discord_callback.php"

# ==========================================
# API Integrations
# ==========================================
# Used by the cron scripts for generating new AI Bounties
GEMINI_API_KEY="your_gemini_api_key_here"

# Used by the Discord bot integration
BOT_API_SECRET="your_bot_secret_here"

# Used by cron_streak_alert.php to send DM notifications via the Discord Bot
BOT_TOKEN="your_discord_bot_token_here"

# Used by the mailing system to bypass port 25 blocks, leave empty to use local sendmail string
BREVO_API_KEY=""

# The sender address for outgoing emails
SMTP_FROM="noreply@psobb.io"
