                'Angel/Luck' => 40, 'Angel/Mind' => 40, 'Dragon/HP' => 40, 'HP/Generate' => 40, 
                'HP/Restorate' => 40, 'PB/Amplifier' => 40, 'PB/Generate' => 40, 'TP/Generate' => 40, 
                'TP/Restorate' => 40, 'Resist/Cold' => 40, 'Resist/Dark' => 40, 'Resist/Evil' => 40, 
                'Resist/Fire' => 40, 'Resist/Flame' => 40, 'Resist/Freeze' => 40, 'Resist/Light' => 40, 
                'Resist/Saint' => 40, 'Resist/Shock' => 40, 'Resist/Thunder' => 40
            ];
        } else if ($bracket >= 3) {
            $pool = [
                'Master/Ability' => 40, 'Super/Resist' => 40, 'Trap/Search' => 40, 
                'Cure/Shock' => 20, 'Cure/Freeze' => 20, 'Cure/Paralysis' => 20, 'Cure/Confuse' => 20,
                'God/Battle' => 10, 'God/Ability' => 10, 'God/Power' => 20, 'God/Mind' => 20
            ];
        }

    } else if ($category === 'Random') {
        if ($bracket == 1) {
            $pool = [
                'Trigrinder' => 50, 'Monogrinder' => 100, 'Digrinder' => 100, 
                'Power Material' => 100, 'Mind Material' => 100, 'Def Material' => 100, 
                'Evade Material' => 100, 'HP Material' => 80, 'TP Material' => 80,
                'AddSlot' => 40, 'Photon Drop x2' => 100, 'Disk:Shifta Lv.15' => 50, 
                'Disk:Deband Lv.15' => 50
            ];
        } else if ($bracket == 2) {
            $pool = [
                'Trigrinder' => 100, 'Power Material' => 100, 'Mind Material' => 100, 
                'HP Material' => 80, 'Luck Material' => 60, 'AddSlot' => 80, 
                'Photon Drop x10' => 100, 'Photon Sphere' => 10, 'Cure/Shock' => 40, 
                'Cure/Freeze' => 40, 'Cure/Paralysis' => 40, 'Cure/Confuse' => 40, 
                'God/Battle' => 30, 'God/Ability' => 30, 'God/Power' => 50, 'God/Mind' => 50,
                'Photon Crystal' => 50, 'Amitie\'s Memo' => 10, 'Heart of Morolian' => 10
            ];
        } else if ($bracket == 3) {
            $pool = [
                'Trigrinder' => 100, 'Power Material' => 100, 'Mind Material' => 100, 
                'HP Material' => 80, 'Luck Material' => 60, 'AddSlot' => 80,
                'Photon Sphere' => 50, 'Heavenly/Battle' => 40, 'Heavenly/Ability' => 40,
                'Heavenly/Power' => 60, 'Heavenly/Mind' => 60, 'Heavenly/Arms' => 60,
                'V501' => 20, 'Centurion/Ability' => 5, 'Blue-Black Stone' => 30, 
                'Star Amplifier' => 40, 'Syncesta' => 20, 'Photon Crystal' => 50, 'D-Photon Core' => 10,
                'Pioneer Parts' => 10, 'Yahoo!\'s engine' => 10
            ];
        } else if ($bracket == 4) {
            $pool = [
                'Trigrinder' => 100, 'Luck Material' => 60, 'AddSlot' => 80,
                'Photon Sphere' => 80, 'Red Ring' => 2, 'Parasitic Gene "Flow"' => 5, 
                'V101' => 15, 'V502' => 15, 'V801' => 15, 'LIMITER' => 5, 'ADEPT' => 5,
                'SWORDSMAN LORE' => 10, 'PROOF OF SWORD-SAINT' => 10, 'SMARTLINK' => 20,
                'DIVINE PROTECTION' => 10, 'Centurion/Ability' => 10, 'Disk:Grants Lv.30' => 40, 
                'Disk:Megid Lv.30' => 40, 'Photon Crystal' => 50, 
                'Heaven Striker Coat' => 10, 'Liberta Kit' => 10, 'Tablet' => 10
            ];
        }
    }
    
    return get_weighted_random($pool);
}

function get_common_reward_item($level_milestone, $charClass, $category) {
    // Determine the tier based on milestone (roughly matches equip requirements)
    $tier = 1;
    if ($level_milestone >= 95) $tier = 6;
    else if ($level_milestone >= 65) $tier = 5;
    else if ($level_milestone >= 45) $tier = 4;
    else if ($level_milestone >= 25) $tier = 3;
    else if ($level_milestone >= 15) $tier = 2;

    $specials = ['Charge', 'Berserk', 'Spirit', 'Arrest', 'Blizzard', 'Hell', 'Demon\'s', 'Geist', 'Gush'];
    
    // Group classes
    $isHunter = in_array($charClass, ['HUmar', 'HUnewearl', 'HUcast', 'HUcaseal']);
    $isRanger = in_array($charClass, ['RAmar', 'RAmarl', 'RAcast', 'RAcaseal']);
    $isForce = !$isHunter && !$isRanger;
    
    if ($category === 'Weapon') {
        $weapons = [];
        if ($isHunter) {
            switch ($tier) {
                case 1: $weapons = ['Saber', 'Sword', 'Dagger', 'Partisan', 'Slicer', 'Handgun']; break;
                case 2: $weapons = ['Brand', 'Gigush', 'Knife', 'Halbert', 'Spinner', 'Autogun']; break;
                case 3: $weapons = ['Buster', 'Breaker', 'Blade', 'Glaive', 'Cutter', 'Lockgun']; break;
                case 4: $weapons = ['Pallasch', 'Claymore', 'Edge', 'Berdys', 'Sawcer', 'Railgun']; break;
                case 5: $weapons = ['Gladius', 'Calibur', 'Ripper', 'Gungnir', 'Diska', 'Raygun']; break;
                case 6: $weapons = ['Gladius', 'Calibur', 'Ripper', 'Gungnir', 'Diska', 'Raygun']; break;
            }
        } else if ($isRanger) {
            switch ($tier) {
                case 1: $weapons = ['Rifle', 'Shot', 'Mechgun', 'Handgun', 'Slicer', 'Saber']; break;
                case 2: $weapons = ['Sniper', 'Spread', 'Assault', 'Autogun', 'Spinner', 'Brand']; break;
                case 3: $weapons = ['Blaster', 'Cannon', 'Repeater', 'Lockgun', 'Cutter', 'Buster']; break;
                case 4: $weapons = ['Beam', 'Launcher', 'Gatling', 'Railgun', 'Sawcer', 'Pallasch']; break;
                case 5: $weapons = ['Laser', 'Arms', 'Vulcan', 'Raygun', 'Diska', 'Gladius']; break;
                case 6: $weapons = ['Laser', 'Arms', 'Vulcan', 'Raygun', 'Diska', 'Gladius']; break;
            }
        } else { // Forces
            switch ($tier) {
                case 1: $weapons = ['Cane', 'Rod', 'Wand', 'Handgun', 'Slicer']; break;
                case 2: $weapons = ['Stick', 'Pole', 'Staff', 'Autogun', 'Spinner']; break;
                case 3: $weapons = ['Mace', 'Pillar', 'Baton', 'Lockgun', 'Cutter']; break;
                case 4: $weapons = ['Club', 'Striker', 'Scepter', 'Railgun', 'Sawcer']; break;
                case 5: $weapons = ['Club', 'Striker', 'Scepter', 'Raygun', 'Diska']; break;
                case 6: $weapons = ['Club', 'Striker', 'Scepter', 'Raygun', 'Diska']; break;
            }
        }
        
        $chosenWeapon = $weapons[array_rand($weapons)];
        $chosenSpecial = $specials[array_rand($specials)];
        
        return "? $chosenSpecial $chosenWeapon";
        
    } else if ($category === 'Armor') {
        $frames = [];
        $armors = [];
        switch ($tier) {
            case 1: $frames = ['Frame', 'Psy Frame', 'Giga Frame']; $armors = ['Armor', 'Psy Armor']; break;
            case 2: $frames = ['Soul Frame', 'Cross Frame']; $armors = ['Giga Armor', 'Soul Armor', 'Cross Armor']; break;
            case 3: $frames = ['Solid Frame', 'Brave Frame', 'Hyper Frame']; $armors = ['Solid Armor', 'Brave Armor']; break;
            case 4: $frames = ['Grand Frame', 'Valiant Frame']; $armors = ['Hyper Armor', 'Grand Armor', 'Valiant Armor']; break;
            case 5: $frames = ['Imperial Frame', 'Protect Frame']; $armors = ['Imperial Armor', 'Protect Armor']; break;
            case 6: $frames = ['Ultimate Frame']; $armors = ['Celestial Armor', 'Divinity Armor']; break;
        }
        
        $isNewman = in_array($charClass, ['HUnewearl', 'FOnewm', 'FOnewearl']);
        
        // Newmans can only equip frames. Everyone else can equip both frames and armors.
        $validArmors = $isNewman ? $frames : array_merge($frames, $armors);
        
        $chosenArmor = $validArmors[array_rand($validArmors)];
        return "$chosenArmor";
        
    } else if ($category === 'Shield') {
        $barriers = [];
        $shields = []; // Shields are normally unequippable by Forces
        switch ($tier) {
            case 1: $barriers = ['Barrier', 'Core Barrier', 'Psy Barrier']; $shields = ['Shield', 'Core Shield']; break;
            case 2: $barriers = ['Giga Barrier', 'Soul Barrier']; $shields = ['Psy Shield', 'Giga Shield', 'Soul Shield']; break;
            case 3: $barriers = ['Hard Barrier', 'Brave Barrier', 'Solid Barrier']; $shields = ['Hard Shield', 'Brave Shield']; break;
            case 4: $barriers = ['Flame Barrier', 'Plasma Barrier']; $shields = ['Solid Shield', 'Flame Shield', 'Plasma Shield']; break;
            case 5: $barriers = ['Freeze Barrier', 'Glorious Barrier']; $shields = ['Freeze Barrier', 'Glorious Shield']; break;
            case 6: $barriers = ['Imperial Barrier', 'Divinity Barrier']; $shields = ['Imperial Barrier', 'Ultimate Shield', 'Celestial Shield']; break;
        }
        
        // Forces typically can only equip barriers, with few exceptions. Play it safe by only rewarding barriers to FO.
        $validShields = $isForce ? $barriers : array_merge($barriers, $shields);

        $chosenShield = $validShields[array_rand($validShields)];
        // DEF/EVP bonus syntax handled downstream
        return $chosenShield;
    } else if ($category === 'Unit') {
        $units = [];
        switch ($tier) {
            case 1: $units = ['Knight/Power', 'Priest/Mind', 'Thief/Legs', 'Warrior/Body']; break;
            case 2: $units = ['General/Power', 'General/Mind', 'General/Legs', 'General/Body', 'General/Arm', 'General/HP']; break;
            case 3: $units = ['Ogre/Power', 'Digger/HP', 'Elf/Legs', 'Elf/Arm', 'Marksman/Arm', 'Wizard/Technique']; break;
            case 4: $units = ['Dragon/HP', 'Angel/Mind', 'Angel/Luck', 'God/Power']; break;
            case 5: $units = ['Master/Ability', 'HP/Generate', 'TP/Generate', 'PB/Generate']; break;
            case 6: $units = ['HP/Restorate', 'TP/Restorate', 'PB/Amplifier']; break;
        }
        $chosenUnit = $units[array_rand($units)];
        return $chosenUnit;
    }
    
    // Fallback if bad category
    return 'Meseta 1000';
}
?>